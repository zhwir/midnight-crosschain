export struct TokenPairInfo {
  fromChainId: Uint<32>;
  toChainId: Uint<32>;
  midnigthTokenAccount: Bytes<32>;
  domainSep: Bytes<32>;
  fee: Uint<128>; 
}


export struct CrossOutBound {
  smgId: Bytes<32>;
  fromAddr: ZswapCoinPublicKey;
  toAddr: Opaque<"string">;
  tokenPairId: Uint<32>;
  tokenAccount: Bytes<32>;
  amount: Uint<128>;
  fee: Uint<128>;
}

export struct CrossProposal{
  smgId: Bytes<32>;
  token: Bytes<32>;
  tokenPairId: Uint<32>;
  isMappingToken: Boolean;
  amount: Uint<128>;
  fee: Uint<128>;
  toAddr: UserAddress;
  ttl: Uint<64>;
}

export struct SmgEvent{
  uniqueId: Bytes<32>;
  crossProposal: CrossProposal;
}

export struct VoteForCrossPropasal{
  uniqueId: Bytes<32>;
  ttl: Uint<64>;
}

constructor(
  adminThresholdInit: Uint<8>
  , smgPKThresholdInit: Uint<8>
  ,feeReceiverInit: UserAddress
) {
    owner = ownPublicKey();
    worker = ownPublicKey();
    tokenManager = ownPublicKey();
    // feeReceiver = disclose(feeUnshieldedReceiverInit);
    adminThreshold = disclose(adminThresholdInit);
    smgPKThreshold = disclose(smgPKThresholdInit);
    feeReceiver = disclose(feeReceiverInit);
    proposalId.increment(1);
    // maxRemainedHisOfTtl = 3600 * 24 * 30 * 2;
}
