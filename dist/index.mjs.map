export enum ProposalType{
  AddAdmin,
  RemoveAdmin,
  UpdateFeeReceiver,
  UpdateTokenManager,
  UpdateAdminThreshold,
  UpdateSMGPKThreshold,
  UpdateFeeCommonConfig,
  SetSmgPKS
}

export struct FeeConfig{
  chainId: Uint<32>;
  fee: Uint<128>;
}

export struct Proposal{
  pType: ProposalType;
  addr: ZswapCoinPublicKey;
  addrUnshielded: UserAddress;
  threshold: Uint<128>;
  feeConfig: FeeConfig;
  smgPubkeys: Vector<29, ZswapCoinPublicKey>;
}

// owner related state
