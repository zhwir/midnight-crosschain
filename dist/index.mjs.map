// }
circuit receiveFee(amount: Uint<128>): [] {
  receiveUnshielded(nativeToken(), amount);
  updateReserve(false, nativeToken(), amount, true);
}

export circuit userLock(smgId: Bytes<32>, toAddr: Opaque<"string">, tokenPairId: Uint<32>, amount: Uint<128>): [] {
  assert(disclose(amount) > 0, "amount must be greater than 0");
  assert(tokenPairs.member(disclose(tokenPairId)),"tokenpairId not exists");
  const tokenPair = tokenPairs.lookup(disclose(tokenPairId));
  // const midnightTokenAccount = tokenPairs.lookup(disclose(tokenPairId)).midnigthTokenAccount;
  assert(tokenPair.domainSep == default<Bytes<32>>, "not support mapping token");

  const contractFee = getFee(disclose(tokenPairId));

  receiveUnshielded(tokenPair.midnigthTokenAccount, disclose(amount));
  // receiveUnshielded(nativeToken(), disclose(amount));
  // receiveUnshielded(nativeToken(), 1009);
  if(contractFee > 0) receiveFee(contractFee);

  // record the crosschain info
  latestOutBoundCrosstxInfo = CrossOutBound{
    smgId: disclose(smgId)
    , fromAddr: ownPublicKey()
    , toAddr: disclose(toAddr)
    , tokenPairId: disclose(tokenPairId)
    , tokenAccount: tokenPair.midnigthTokenAccount
    , amount: disclose(amount)
    , fee: contractFee 
  };
}

export circuit smgRelease(
  uniqueId: Bytes<32>
  , smgId: Bytes<32>
  , tokenPairId: Uint<32>
  , amount: Uint<128>
  , toAddr: UserAddress
  , fee: Uint<128>
  , ttl: Uint<64>): [] {
  assert(tokenPairs.member(disclose(tokenPairId)),"tokenpairId not exists");
  const tokenPair = tokenPairs.lookup(disclose(tokenPairId));
  assert (tokenPair.domainSep == default<Bytes<32>>, "smgRelease not support mapping token");

  addCrossProposal(disclose(uniqueId), disclose(smgId), disclose(tokenPairId),tokenPair, disclose(amount), disclose(toAddr), disclose(fee), disclose(ttl));
}

export circuit smgMint(uniqueId: Bytes<32>
  , smgId: Bytes<32>
  , tokenPairId: Uint<32>
  , amount: Uint<128>
  , fee: Uint<128>
  , toAddr: UserAddress
  , ttl: Uint<64>): [] {
  assert(tokenPairs.member(disclose(tokenPairId)),"tokenpairId not exists");
  const tokenPair = tokenPairs.lookup(disclose(tokenPairId));
  assert (tokenPair.domainSep != default<Bytes<32>>, "smgMint only support mapping token");
    
  addCrossProposal(disclose(uniqueId), disclose(smgId), disclose(tokenPairId), tokenPair, disclose(amount), disclose(toAddr), disclose(fee), disclose(ttl));
}


export circuit userBurn(smgId: Bytes<32>, toAddr: Opaque<"string">, tokenPairId: Uint<32>, amount: Uint<128>): [] {
  assert(tokenPairs.member(disclose(tokenPairId)),"tokenpairId not exists");
  assert(disclose(amount) > 0, "amount must be greater than 0");
  const tokenPair = tokenPairs.lookup(disclose(tokenPairId));
  assert(tokenPair.domainSep != default<Bytes<32>>, "only support mapping token");
  const contractFee = getFee(disclose(tokenPairId));

  if(contractFee > 0) receiveFee(contractFee);
  _burn(tokenPair.midnigthTokenAccount, disclose(amount));

    // record the crosschain info
  latestOutBoundCrosstxInfo = CrossOutBound{
    smgId: disclose(smgId)
    , fromAddr: ownPublicKey()
    , toAddr: disclose(toAddr)
    , tokenPairId: disclose(tokenPairId)
    , tokenAccount: tokenPair.midnigthTokenAccount
    , amount: disclose(amount)
    , fee: contractFee
  };

}

circuit addCrossProposal(
  uniqueId: Bytes<32>
  , smgId: Bytes<32>
  , tokenPairId: Uint<32>
  , tokenPair: TokenPairInfo
  , amount: Uint<128>
  , toAddr: UserAddress
  , fee: Uint<128>
  , ttl: Uint<64>
  // , isMappingToken: Boolean
): [] {
  assert(crossProposalHis.member(disclose(uniqueId)) == false, "crossTx has finished");
  assert(smgTxSigners.member(ownPublicKey()), "not smg member");
  assert(disclose(amount) > 0, "amount must be greater than 0");
  assert(disclose(amount) > disclose(fee), "amount must be greater than fee");

  if(crossProposal.member(disclose(uniqueId))){
     if(blockTimeLt(crossProposal.lookup(disclose(uniqueId)).ttl) || (crossProposalVoters.lookup(disclose(uniqueId)).size() >= smgPKThreshold)){
       assert(false,"proposal exists");
     }else{
       crossProposal.remove(disclose(uniqueId));
       crossProposalVoters.remove(disclose(uniqueId));
     }
  }
  assert( blockTimeLt(disclose(ttl)), "ttl expired");
  // assert(tokenPairs.member(disclose(tokenPairId)),"tokenpairId not exists");

  // const tokenPair = tokenPairs.lookup(disclose(tokenPairId));
  
  const isMappingToken = tokenPair.domainSep != default<Bytes<32>>;
  
  const newCrossProposal = CrossProposal{ 
    smgId: disclose(smgId)
    , token: isMappingToken?tokenPair.domainSep :tokenPair.midnigthTokenAccount
    , tokenPairId: disclose(tokenPairId)
    , isMappingToken: isMappingToken
    , amount: disclose(amount)
    , fee: disclose(fee)
    , toAddr: disclose(toAddr)
    , ttl: disclose(ttl)
    };

  // //TODO: need to check add the same proposal again
 
  crossProposal.insert(disclose(uniqueId),newCrossProposal);
  crossProposalVoters.insertDefault(disclose(uniqueId));

  // _voteCrossProposal(newCrossProposal);
  // crossCounter.increment(1);
  const voterIndex = smgTxSigners.lookup(ownPublicKey());
  // if(crossProposalVoters.lookup(uniqueId).member(voterIndex)) return;

  crossProposalVoters.lookup(uniqueId).insert(voterIndex);
}

export circuit voteMultiCrossProposal(uniqueIds: Vector<5, VoteForCrossPropasal>): [] {

  if(!smgTxSigners.member(ownPublicKey())) return;

  for (const target of disclose(uniqueIds)) {
    if(target.uniqueId != default<Bytes<32>> && crossProposal.member(target.uniqueId)) {
      const proposal = crossProposal.lookup(target.uniqueId);
      if(crossProposalVoters.lookup(target.uniqueId).size() < smgPKThreshold){
        if(proposal.ttl == target.ttl) {
          if(blockTimeGte(proposal.ttl)){
            crossProposal.remove(target.uniqueId);
            crossProposalVoters.remove(target.uniqueId);
          }else{
            const voterIndex = smgTxSigners.lookup(ownPublicKey());
            crossProposalVoters.lookup(target.uniqueId).insert(voterIndex);
          }
        }
      }
      
    }
  }
    
}

circuit updateReserve(isMappingToken: Boolean,token: Bytes<32>, delta: Uint<128>, isAdd: Boolean): [] {
  assert(delta > 0, "delta must be positive");
  const oldAmount = reserveOfAllToken.member(disclose(token))? reserveOfAllToken.lookup(disclose(token)).total : 0;
  assert(isAdd || oldAmount >= delta, "delta must be less than or equal to oldAmount");
  assert (oldAmount == 0 || reserveOfAllToken.lookup(disclose(token)).isMappingToken == isMappingToken, "token type mismatch");
  

  const newAmount = isAdd ? oldAmount + delta : oldAmount - delta;

  if(newAmount == 0){
    reserveOfAllToken.remove(disclose(token));
  }else{
    reserveOfAllToken.insert(disclose(token),ReserveOfToken{total: newAmount as Uint<128>,isMappingToken: isMappingToken});
  }
}

circuit withdrawReserve(token: Bytes<32>): [] {
  assert(reserveOfAllToken.member(disclose(token)),"token not exists in reserve");
  const reserveInfo = reserveOfAllToken.lookup(disclose(token));
  assert (reserveInfo.total > 0, "reserve amount must be positive");
  
  
  if(reserveInfo.isMappingToken){
    mintUnshieldedToken(disclose(token), reserveInfo.total as Uint<64>, right<ContractAddress, UserAddress>(feeReceiver));
  }else{
    sendUnshielded(disclose(token), reserveInfo.total as Uint<128>, right<ContractAddress, UserAddress>(feeReceiver));
  }

  updateReserve(reserveInfo.isMappingToken, token, reserveInfo.total as Uint<128>, false);
}

circuit _transfer(uniqueId: Bytes<32>, token: Bytes<32>, toAddr: UserAddress, amount: Uint<128>, fee: Uint<128>):[] {
  // tokenToBeClaimed.insert(uniqueId, ClaimTokenInfo{
  //         receiver: toAddr
  //         , token: token
  //         , isMappingToken: false
  //         , amount: (amount-fee) as Uint<128>
  //         });
  if(fee > 0) {
    // updateReserve(false, token, fee, true);
    sendUnshielded(token,fee, right<ContractAddress, UserAddress>(feeReceiver));
  }
  sendUnshielded(token, amount, right<ContractAddress, UserAddress>(toAddr));
}

circuit _mint(uniqueId: Bytes<32>, domainSep: Bytes<32>, toAddr: UserAddress, amount: Uint<128>, fee: Uint<128>): [] {
  const color = tokenType(domainSep, kernel.self());
  updateTokenTotalSupply(color, amount, true);

  if(fee > 0) {
    // updateReserve(true, domainSep, fee, true);
    mintUnshieldedToken(domainSep, fee as Uint<64>, right<ContractAddress, UserAddress>(feeReceiver));
  }

  // tokenToBeClaimed.insert(uniqueId, ClaimTokenInfo{
  //   receiver: toAddr
  //   , token: domainSep
  //   , isMappingToken: true
  //   , amount: (amount - fee) as Uint<128>
  // });
  mintUnshieldedToken(domainSep, amount as Uint<64>, right<ContractAddress, UserAddress>(toAddr));
}

export circuit executeCrossProposal(uniqueId: Bytes<32>): [] {
  
  assert(smgTxSigners.member(ownPublicKey()), "only smgTxSigners can executeCrossProposal ");
  assert( crossProposal.member(disclose(uniqueId)), "proposal not exists");
  assert( crossProposalVoters.lookup(disclose(uniqueId)).size() >= smgPKThreshold, "not enough votes");

  currentExecuteCrossProposal.resetToDefault();

  const proposal = crossProposal.lookup(disclose(uniqueId));
  if(proposal.isMappingToken == false){
    _transfer(disclose(uniqueId), proposal.token, proposal.toAddr, proposal.amount as Uint<128>, proposal.fee as Uint<128>);
  }else{
    const tokenPair = tokenPairs.lookup(proposal.tokenPairId);
    _mint(disclose(uniqueId), proposal.token, proposal.toAddr, proposal.amount as Uint<128>, proposal.fee as Uint<128>);
  }
          
  currentExecuteCrossProposal = SmgEvent{uniqueId:disclose(uniqueId),crossProposal:proposal};
  crossProposalHis.insert(disclose(uniqueId),proposal.ttl);
  crossProposal.remove(disclose(uniqueId));
  crossProposalVoters.remove(disclose(uniqueId));
}

circuit updateTokenTotalSupply(token: Bytes<32>, delta: Uint<128>, isAdd: Boolean): [] {
  assert(delta > 0, "delta must be positive");
  const oldTotalSupply = mappingTokenTotalSupply.member(disclose(token)) ? mappingTokenTotalSupply.lookup(disclose(token)) : 0;
  assert(isAdd || oldTotalSupply >= delta, "delta must be less than or equal to oldTotalSupply");

  const newTotalSupply = isAdd ? (oldTotalSupply + delta) : (oldTotalSupply - delta);

  if(newTotalSupply == 0){
    mappingTokenTotalSupply.remove(disclose(token));
  }else{
    mappingTokenTotalSupply.insert(disclose(token),newTotalSupply as Uint<128>);
  }
}


circuit _burn(color: Bytes<32>, amount: Uint<128>): [] {
  receiveUnshielded(color, amount);
  sendUnshielded(color, disclose(amount), right<ContractAddress, UserAddress>(UserAddress{bytes: 0 as Field as Bytes<32>})); // burn address
  updateTokenTotalSupply(color, amount, false);
}


// if fee is 0 ,cross fee is specified by feeConfig
circuit getFee(tokenPairId: Uint<32>): Uint<128> {
  const tokenPair = tokenPairs.lookup(tokenPairId);
  if(tokenPair.fee == 0) {
    if(feeCommonConfig.member(tokenPair.toChainId)){
      return feeCommonConfig.lookup(tokenPair.toChainId);
    }else {
      return 0;
    }
  } else {
    return tokenPair.fee;
  }
}

