{
  "name": "midnight-crosschain-light",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "imports": {
    "#self": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "compactc": "compactc --vscode  contract/crosschain.compact src/managed/crosschain",
    "compact": "compact compile --vscode  contract/crosschain.compact src/managed/crosschain",
    "compact-check": "compact compile --vscode --skip-zk contract/crosschain.compact src/managed/crosschain",
    "build-es": "esbuild --bundle src/index.ts --outfile=dist/index.cjs --platform=node --target=node22 --format=cjs",
    "build": "rm -rf dist && tsup && cp -Rf ./src/managed ./dist && cp ./node_modules/@midnight-ntwrk/ledger-v8/midnight_ledger_wasm_bg.wasm ./dist/ && cp ./node_modules/@midnight-ntwrk/onchain-runtime-v3/midnight_onchain_runtime_wasm_bg.wasm ./dist/ && cp ./node_modules/@midnight-ntwrk/zkir-v2/midnight_zkir_wasm_bg.wasm ./dist/ && cp ./node_modules/source-map/lib/mappings.wasm ./dist/",
    "lint": "eslint src",
    "typecheck": "npx tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fridayback/midnight-crosschain.git"
  },
  "keywords": [
    "midnight-crosschain"
  ],
  "author": "WanChain",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/fridayback/midnight-crosschain/issues"
  },
  "homepage": "https://github.com/fridayback/midnight-crosschain#readme",
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "testcontainers": "^11.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "0.15.0",
    "@midnight-ntwrk/midnight-js-contracts": "4.0.2",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-network-id": "4.0.2",
    "@midnight-ntwrk/midnight-js-types": "4.0.2",
    "@midnight-ntwrk/midnight-js-utils": "4.0.2",
    "@midnight-ntwrk/wallet-sdk-facade": "3.0.0",
    "axios": "^1.13.4",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "ws": "^8.18.2"
  }
}
